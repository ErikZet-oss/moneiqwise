DATABASE_URL=postgresql://postgres:postgres@localhost:5432/moneiqwise
PORT=5000

# Local auth session settings
LOCAL_AUTH_ALLOW_REMOTE=false
LOCAL_AUTH_SESSION_SECRET=please-change-me
# Production: set SESSION_SECRET to a long random value (32+ chars)
SESSION_SECRET=
# Optional: comma-separated allowed registration emails. Empty = no allowlist.
LOCAL_AUTH_EMAIL_ALLOWLIST=
LOCAL_AUTH_RESET_TOKEN_MINUTES=30
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=25
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# Optional API keys
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
